{
  "name": "@deskwork/cli",
  "version": "0.14.1",
  "type": "module",
  "description": "Editorial calendar + review CLI for the deskwork plugin",
  "homepage": "https://github.com/audiocontrol-org/deskwork#readme",
  "license": "GPL-3.0-or-later",
  "author": "audiocontrol-org",
  "repository": {
    "type": "git",
    "url": "https://github.com/audiocontrol-org/deskwork.git",
    "directory": "packages/cli"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "package.json",
    "README.md"
  ],
  "bin": {
    "deskwork": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -b tsconfig.build.json && chmod +x dist/cli.js",
    "prepack": "tsc -b tsconfig.build.json && chmod +x dist/cli.js",
    "dev": "tsc -b tsconfig.build.json --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@deskwork/core": "0.14.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "esbuild": "^0.24.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.2"
  }
}
