{
  "name": "@deskwork/studio",
  "version": "0.9.5",
  "type": "module",
  "description": "Editorial review studio — local web UI for the deskwork plugin",
  "homepage": "https://github.com/audiocontrol-org/deskwork#readme",
  "license": "GPL-3.0-or-later",
  "author": "audiocontrol-org",
  "repository": {
    "type": "git",
    "url": "https://github.com/audiocontrol-org/deskwork.git",
    "directory": "packages/studio"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "package.json",
    "README.md"
  ],
  "bin": {
    "deskwork-studio": "./dist/server.js"
  },
  "exports": {
    ".": {
      "types": "./dist/server.d.ts",
      "default": "./dist/server.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc -b tsconfig.build.json",
    "prepack": "tsc -b tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.41.1",
    "@deskwork/core": "*",
    "@hono/node-server": "^1.13.7",
    "@lezer/highlight": "^1.2.3",
    "esbuild": "^0.28.0",
    "hono": "^4.6.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.2"
  }
}
