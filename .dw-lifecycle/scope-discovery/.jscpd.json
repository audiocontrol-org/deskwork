{
  "format": ["typescript", "tsx", "bash"],
  "pattern": "**/*.{ts,tsx,sh,bash}",
  "ignore": [
    "**/*.test.ts",
    "**/dist/**",
    "**/node_modules/**",
    "**/.runtime-cache/**",
    "**/coverage/**",
    ".specify/**"
  ],
  "minTokens": 50,
  "gitignore": true,
  "reporters": ["json"],
  "output": "reports/duplication"
}
