#!/usr/bin/env bash
#
# pre-push — no-op stub.
#
# The scope-discovery pre-push audit-coverage gate that lived here
# (check-implement-hook-coverage) was retired as part of Phase 24
# (no-git-hook-enforcement contract). The discipline relocates into
# skill bodies — /dw-lifecycle:implement runs the audit-barrage at task
# boundaries and refuses to advance with open findings.
#
# Adopters get the discipline by installing the plugin, not by wiring
# git hooks.
#
# Husky 9 invokes hooks via sh, not bash, regardless of the shebang. On
# Debian-family hosts /bin/sh is dash, which does NOT support
# `set -o pipefail`. Stick to posix-compat strict mode (set -eu).

set -eu

exit 0
