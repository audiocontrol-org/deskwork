#!/usr/bin/env bash
#
# pre-push — currently a no-op.
#
# Phase 23b (source-shipped re-architecture) retired the committed
# bundles (`plugins/deskwork/bundle/cli.mjs`,
# `plugins/deskwork-studio/bundle/server.mjs`) and the on-push rebuild
# step that kept them in sync. The plugin tree now ships source only;
# adopters run `npm install --omit=dev` once and `tsx` runs source
# thereafter (see `plugins/<name>/bin/<wrapper>` for the resolution
# order). There is therefore nothing for pre-push to verify against
# source drift.
#
# The hook file is kept so future push-time checks can be added without
# re-bootstrapping husky. To add one: implement it here and exit non-zero
# on failure.
#
# Husky 9 invokes hooks via sh, not bash, regardless of the shebang. On
# Debian-family hosts (CI runners included) /bin/sh is dash, which does
# NOT support `set -o pipefail`. Stick to posix-compat strict mode
# (set -eu) and check pipe results explicitly with $? if needed. Adding
# `set -o pipefail` here will silently break the release workflow's
# "Commit materialized vendor + re-point tag" step (regression: v0.9.1
# release run 25126363101).

set -eu
exit 0
