#!/usr/bin/env bash
#
# pre-push — currently a no-op.
#
# Phase 23b (source-shipped re-architecture) retired the committed
# bundles (`plugins/deskwork/bundle/cli.mjs`,
# `plugins/deskwork-studio/bundle/server.mjs`) and the on-push rebuild
# step that kept them in sync. The plugin tree now ships source only;
# adopters run `npm install --omit=dev` once and `tsx` runs source
# thereafter (see `plugins/<name>/bin/<wrapper>` for the resolution
# order). There is therefore nothing for pre-push to verify against
# source drift.
#
# The hook file is kept so future push-time checks can be added without
# re-bootstrapping husky. To add one: implement it here, set -euo
# pipefail, exit non-zero on failure.

set -euo pipefail
exit 0
