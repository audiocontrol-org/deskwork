#!/usr/bin/env bash
#
# pre-commit — keep the runnable bundles in sync with their source.
#
# Per the install-gap fix shipped in 956cd2d (issue #4), the committed
# bundles live inside the plugin tree (so marketplace installs find
# them after Claude copies plugins/<name>/ into its plugin cache):
#
#   plugins/deskwork/bundle/cli.mjs           ← @deskwork/cli build output
#   plugins/deskwork-studio/bundle/server.mjs ← @deskwork/studio build output
#
# When source under packages/{core,cli,studio}/src/ is staged, the
# corresponding bundle in plugins/<name>/bundle/ must reflect the new
# source. This hook rebuilds the affected bundle(s) and re-stages them,
# so a stale bundle never lands in a commit.
#
# - Skipped silently when no source is staged.
# - Idempotent: rebuilding when bundle was already correct is a no-op.
# - The build is fast (esbuild ~1s per package); contributors who edit
#   only docs / tests / READMEs see no overhead.

set -euo pipefail

staged="$(git diff --cached --name-only --diff-filter=ACMR)"

needs_cli=false
needs_studio=false

while IFS= read -r f; do
  [ -z "$f" ] && continue
  case "$f" in
    # Core changes invalidate BOTH bundles (both inline @deskwork/core).
    packages/core/src/*) needs_cli=true; needs_studio=true ;;
    packages/cli/src/*) needs_cli=true ;;
    packages/studio/src/*) needs_studio=true ;;
  esac
done <<< "$staged"

rebuild_one() {
  local pkg="$1"
  local plugin_name="$2"
  local bundle="$3"
  local out_path="plugins/${plugin_name}/bundle/${bundle}"
  echo "[deskwork pre-commit] rebuilding ${out_path} (source under packages/${pkg}/src/ staged)"
  npm --workspace "packages/${pkg}" run build > /dev/null
  git add "${out_path}"
}

if [ "$needs_cli" = true ]; then
  rebuild_one "cli" "deskwork" "cli.mjs"
fi

if [ "$needs_studio" = true ]; then
  rebuild_one "studio" "deskwork-studio" "server.mjs"
fi
