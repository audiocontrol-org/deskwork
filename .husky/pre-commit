#!/usr/bin/env bash
#
# Husky 9 invokes hooks via sh, not bash, regardless of the shebang. On
# Debian-family hosts /bin/sh is dash, which does NOT support
# `set -o pipefail`. Stick to posix-compat strict mode (set -eu) — same
# fix already applied to .husky/pre-push.
set -eu

# pre-commit — no-op stub.
#
# The scope-discovery gate chain that lived here (detect-clones,
# check-anti-patterns, check-adopters, check-disposition-survivor,
# check-editor-symmetry) was retired as part of Phase 24 (no-git-hook-
# enforcement contract). The discipline relocates into skill bodies —
# /dw-lifecycle:session-start, /dw-lifecycle:implement, /dw-lifecycle:review.
#
# Adopters get the discipline by installing the plugin, not by wiring
# git hooks.

exit 0
