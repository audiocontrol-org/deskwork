#!/usr/bin/env bash
#
# deskwork — wrapper that locates and runs @deskwork/cli.
#
# Resolution order (first match wins):
#   1. Workspace-linked binary (`node_modules/.bin/deskwork`) — the dev
#      path; runs source via tsx, supports edits without rebuild.
#   2. Self-contained ESM bundle at `packages/cli/bundle/cli.mjs` —
#      shipped in the repo, runs via plain `node` with no `npm install`
#      step. This is what fresh `git clone` installs use.
#   3. Loud error.
#
# Either way, the operator's experience is the same: `deskwork <sub>`.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# (1) Workspace symlink — fastest, supports source-level edits.
workspace_candidates=(
  "${SCRIPT_DIR}/../../../node_modules/.bin/deskwork"
  "${SCRIPT_DIR}/../node_modules/.bin/deskwork"
  "${SCRIPT_DIR}/../../node_modules/.bin/deskwork"
)
for candidate in "${workspace_candidates[@]}"; do
  if [ -x "$candidate" ]; then
    exec "$candidate" "$@"
  fi
done

# (2) Self-contained bundle — ships in the repo at packages/cli/bundle/.
bundle_candidates=(
  "${SCRIPT_DIR}/../../../packages/cli/bundle/cli.mjs"
  "${SCRIPT_DIR}/../../packages/cli/bundle/cli.mjs"
)
for candidate in "${bundle_candidates[@]}"; do
  if [ -f "$candidate" ]; then
    exec node "$candidate" "$@"
  fi
done

# (3) Nothing found.
cat >&2 <<EOF
deskwork: cannot locate the @deskwork/cli binary or bundle.

Looked for workspace bin in:
  ${workspace_candidates[0]}
  ${workspace_candidates[1]}
  ${workspace_candidates[2]}

Looked for bundle in:
  ${bundle_candidates[0]}
  ${bundle_candidates[1]}

If you cloned the deskwork repo manually, run 'npm install' at the repo
root to populate node_modules/.bin/, or run 'npm --workspace packages/cli
run build' to produce the bundle.
EOF
exit 127
