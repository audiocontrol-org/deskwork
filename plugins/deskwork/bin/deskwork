#!/usr/bin/env bash
#
# deskwork — thin wrapper around @deskwork/cli (Phase 26c, v0.9.5+).
#
# Resolution order (first match wins):
#   1. Workspace symlink (dev path). When this plugin lives inside the
#      deskwork monorepo, ${PLUGIN_ROOT}/node_modules/@deskwork/cli is a
#      symlink into ../../packages/cli. Detect that case and dispatch
#      directly — never npm-install over a workspace symlink.
#   2. npm-installed at the manifest's pinned version. ${PLUGIN_ROOT}/
#      node_modules/@deskwork/cli/package.json#version === plugin
#      manifest version. Dispatch directly.
#   3. First run, or version drift from a plugin update: npm install
#      --omit=dev @deskwork/cli@<version> into ${PLUGIN_ROOT}, then
#      dispatch. Serialized with a directory-based lock (mkdir is
#      atomic on POSIX; macOS lacks flock(1)).
#
# Plugin shell version === @deskwork/cli npm version (lockstep).

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

PKG_NAME="@deskwork/cli"
BIN_NAME="deskwork"

readonly LOCK_WAIT_SECONDS=180
readonly LOCK_STALE_SECONDS=600
readonly LOCK_POLL_INTERVAL=1

manifest_version() {
  node -e '
    const fs = require("fs");
    const path = process.argv[1];
    const j = JSON.parse(fs.readFileSync(path, "utf8"));
    if (typeof j.version !== "string") {
      console.error("plugin.json missing version");
      process.exit(2);
    }
    process.stdout.write(j.version);
  ' "${PLUGIN_ROOT}/.claude-plugin/plugin.json"
}

installed_version() {
  local pj="${PLUGIN_ROOT}/node_modules/${PKG_NAME}/package.json"
  if [ ! -f "${pj}" ]; then
    return 1
  fi
  node -e '
    const fs = require("fs");
    try {
      const j = JSON.parse(fs.readFileSync(process.argv[1], "utf8"));
      if (typeof j.version === "string") {
        process.stdout.write(j.version);
      }
    } catch (_) {}
  ' "${pj}"
}

# Workspace dev path: when the plugin lives inside the deskwork
# monorepo, npm hoists @deskwork/cli to the workspace root's
# node_modules/, where it's a symlink into ../packages/cli, and the
# bin lives at <root>/node_modules/.bin/deskwork. Detect this by
# walking up from PLUGIN_ROOT for a node_modules/ that contains both
# a @deskwork/<pkg> symlink AND a .bin/<bin> entry. If found, dispatch
# directly — never npm-install over a workspace symlink.
find_workspace_bin() {
  local cur="${PLUGIN_ROOT}"
  while [ "${cur}" != "/" ]; do
    local candidate_link="${cur}/node_modules/${PKG_NAME}"
    local candidate_bin="${cur}/node_modules/.bin/${BIN_NAME}"
    if [ -L "${candidate_link}" ] && [ -x "${candidate_bin}" ]; then
      printf '%s' "${candidate_bin}"
      return 0
    fi
    cur="$(dirname "${cur}")"
  done
  return 1
}

VERSION="$(manifest_version)"

# (1) Workspace dev path.
WORKSPACE_BIN="$(find_workspace_bin || true)"
if [ -n "${WORKSPACE_BIN}" ]; then
  exec "${WORKSPACE_BIN}" "$@"
fi

# (2) Already installed at the right version?
INSTALLED="$(installed_version || true)"
if [ -n "${INSTALLED}" ] && [ "${INSTALLED}" = "${VERSION}" ] \
   && [ -x "${PLUGIN_ROOT}/node_modules/.bin/${BIN_NAME}" ]; then
  exec "${PLUGIN_ROOT}/node_modules/.bin/${BIN_NAME}" "$@"
fi

# (3) First run or version drift — npm install with concurrency lock.
LOCK_DIR="${PLUGIN_ROOT}/.deskwork-install.lock"

stat_mtime_seconds() {
  local path="$1"
  if stat -f '%m' "${path}" >/dev/null 2>&1; then
    stat -f '%m' "${path}"
  elif stat -c '%Y' "${path}" >/dev/null 2>&1; then
    stat -c '%Y' "${path}"
  fi
}

acquire_lock() {
  local waited=0
  while true; do
    if mkdir "${LOCK_DIR}" 2>/dev/null; then
      return 0
    fi
    local now mtime age
    now="$(date +%s)"
    mtime="$(stat_mtime_seconds "${LOCK_DIR}")"
    if [ -n "${mtime}" ]; then
      age=$(( now - mtime ))
      if [ "${age}" -gt "${LOCK_STALE_SECONDS}" ]; then
        echo "${BIN_NAME}: removing stale install lock ${LOCK_DIR} (age=${age}s)" >&2
        rm -rf "${LOCK_DIR}" 2>/dev/null || true
        continue
      fi
    fi
    # Holder may have finished while we polled.
    local cur
    cur="$(installed_version || true)"
    if [ -n "${cur}" ] && [ "${cur}" = "${VERSION}" ] \
       && [ -x "${PLUGIN_ROOT}/node_modules/.bin/${BIN_NAME}" ]; then
      return 2
    fi
    if [ "${waited}" -ge "${LOCK_WAIT_SECONDS}" ]; then
      return 1
    fi
    sleep "${LOCK_POLL_INTERVAL}"
    waited=$(( waited + LOCK_POLL_INTERVAL ))
  done
}

release_lock() {
  rm -rf "${LOCK_DIR}" 2>/dev/null || true
}

if [ -n "${INSTALLED}" ] && [ "${INSTALLED}" != "${VERSION}" ]; then
  echo "${BIN_NAME}: installed ${PKG_NAME}@${INSTALLED} differs from plugin manifest ${VERSION}; reinstalling..." >&2
else
  echo "${BIN_NAME}: first run — installing ${PKG_NAME}@${VERSION} (one-time)..." >&2
fi

acquire_lock
LOCK_STATUS=$?
if [ "${LOCK_STATUS}" -eq 1 ]; then
  cat >&2 <<EOF
${BIN_NAME}: another ${BIN_NAME} install appears to be in progress.
Lock directory: ${LOCK_DIR}
Waited ${LOCK_WAIT_SECONDS}s without acquiring the lock.
If you believe the lock is stale, remove it manually:
  rm -rf "${LOCK_DIR}"
EOF
  exit 75
fi

if [ "${LOCK_STATUS}" -eq 0 ]; then
  # Re-check inside the critical section.
  CUR="$(installed_version || true)"
  if [ -z "${CUR}" ] || [ "${CUR}" != "${VERSION}" ] \
     || [ ! -x "${PLUGIN_ROOT}/node_modules/.bin/${BIN_NAME}" ]; then
    NPM_STDERR="$(mktemp -t "${BIN_NAME}-install.XXXXXX")"
    trap 'release_lock; rm -f "${NPM_STDERR}"' EXIT INT TERM
    NPM_EXIT=0
    # The plugin shell's package.json declares @deskwork/cli at the
    # pinned version. `npm install --omit=dev` reads that and fetches
    # from the registry — no explicit pkg@version arg needed.
    (
      cd "${PLUGIN_ROOT}"
      npm install --omit=dev --no-audit --no-fund --loglevel=error
    ) 2>"${NPM_STDERR}" || NPM_EXIT=$?
    if [ "${NPM_EXIT}" -ne 0 ]; then
      echo "${BIN_NAME}: npm install failed (exit ${NPM_EXIT}). Captured stderr:" >&2
      cat "${NPM_STDERR}" >&2 || true
      release_lock
      rm -f "${NPM_STDERR}"
      trap - EXIT INT TERM
      exit "${NPM_EXIT}"
    fi
    if [ ! -x "${PLUGIN_ROOT}/node_modules/.bin/${BIN_NAME}" ]; then
      echo "${BIN_NAME}: npm install completed but ${PLUGIN_ROOT}/node_modules/.bin/${BIN_NAME} still missing. Captured stderr:" >&2
      cat "${NPM_STDERR}" >&2 || true
      release_lock
      rm -f "${NPM_STDERR}"
      trap - EXIT INT TERM
      exit 1
    fi
    rm -f "${NPM_STDERR}"
    trap - EXIT INT TERM
  fi
  release_lock
fi
# LOCK_STATUS == 2: holder finished successfully.

exec "${PLUGIN_ROOT}/node_modules/.bin/${BIN_NAME}" "$@"
