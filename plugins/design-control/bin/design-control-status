#!/bin/sh
# design-control-status <surface-manifest.json> — evaluate scaffold-mode
# completion for one surface. Exit codes: 0 complete, 1 blocking findings/error,
# 2 usage. Logic lives in src/status/status.ts (tested); this shim only locates
# the workspace tsx runner and dispatches.
set -eu

PLUGIN_ROOT=$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)

dir="$PLUGIN_ROOT"
TSX=""
while [ "$dir" != "/" ]; do
  if [ -x "$dir/node_modules/.bin/tsx" ]; then
    TSX="$dir/node_modules/.bin/tsx"
    break
  fi
  dir=$(dirname -- "$dir")
done

if [ -z "$TSX" ]; then
  echo "design-control-status: tsx runner not found in any node_modules/.bin above $PLUGIN_ROOT — run npm install first" >&2
  exit 1
fi

exec "$TSX" --tsconfig "$PLUGIN_ROOT/tsconfig.json" "$PLUGIN_ROOT/src/status/design-control-status-cli.ts" "$@"
