#!/bin/sh
# design-control-status <surface-manifest.json> — evaluate scaffold-mode
# completion for one surface. Exit codes: 0 complete, 1 blocking findings/error,
# 2 usage. Logic lives in src/status/status.ts (tested); this shim resolves tsx
# (first-run-installing runtime deps in adopter mode) and dispatches.
set -eu

SHIM_NAME=design-control-status
PLUGIN_ROOT=$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)
. "$PLUGIN_ROOT/bin/_resolve-tsx.sh"
resolve_tsx

# --tsconfig pins the plugin's own tsconfig (and its @/* alias); without it tsx
# resolves from the caller's cwd and the documented repo-root invocation crashes.
exec "$TSX" --tsconfig "$PLUGIN_ROOT/tsconfig.json" "$PLUGIN_ROOT/src/status/design-control-status-cli.ts" "$@"
