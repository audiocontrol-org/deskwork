#!/usr/bin/env bash
#
# stackctl — thin wrapper that first-run-installs runtime deps in
# adopter (sparse-clone) mode, then dispatches to src/cli.ts via tsx.
#
# Mirrors plugins/dw-lifecycle/bin/dw-lifecycle's resolution order. The
# runtime deps the dispatched code imports are markdown-it, peggy, yaml,
# and tsx (the document-primitives block-stream / grammar-parse /
# grammar-resolver modules import the first three at runtime). The probe
# list below MUST stay in sync with package.json's "dependencies" — if the
# plugin gains a new runtime dep, add it to RUNTIME_DEPS or an adopter
# install with a partial node_modules/ will skip npm install and then fail
# Node module resolution on first dispatch.
#
# Resolution order (first match wins):
#   1. Workspace dev path: tsx resolves from an ancestor's
#      node_modules/.bin/ via npm workspace hoist. Dispatch via it; the
#      monorepo install owns the full dep set (no install or probe here —
#      hoisted deps resolve from PLUGIN_ROOT via Node's upward lookup).
#   2. Adopter post-install: tsx exists at $PLUGIN_ROOT/node_modules/.bin/tsx
#      AND every declared runtime dep is present under $PLUGIN_ROOT/
#      node_modules. Dispatch via the local tsx.
#   3. First run (or partial install — e.g. tsx present but a later-added
#      runtime dep missing): npm install in $PLUGIN_ROOT, then
#      dispatch. A version-keyed sentinel short-circuits the probe on
#      subsequent runs; a version bump invalidates it and forces a probe.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# Walk up from PLUGIN_ROOT looking for a usable tsx bin. Handles the
# workspace-hoist case (deps land in monorepo root's node_modules/.bin)
# and the adopter post-install case (deps land in this plugin's
# node_modules/.bin).
find_tsx() {
  local cur="${PLUGIN_ROOT}"
  while [ "${cur}" != "/" ]; do
    if [ -x "${cur}/node_modules/.bin/tsx" ]; then
      printf '%s' "${cur}/node_modules/.bin/tsx"
      return 0
    fi
    cur="$(dirname "${cur}")"
  done
  return 1
}

# Read the plugin manifest version; used to name the install-complete
# sentinel so version bumps force a re-probe. Empty string disables the
# sentinel fast-path (every run probes), which is the conservative default.
plugin_version() {
  local manifest="${PLUGIN_ROOT}/.claude-plugin/plugin.json"
  [ -f "${manifest}" ] || { printf ''; return 0; }
  node -e "
    try {
      const m = JSON.parse(require('fs').readFileSync('${manifest}', 'utf8'));
      if (typeof m.version === 'string' && m.version) process.stdout.write(m.version);
    } catch (e) { /* sentinel is optional; never fail the shim over it */ }
  " 2>/dev/null || printf ''
}

# Probe whether a declared runtime dep is installed in the plugin's own
# node_modules/ (test the dep's package.json, not just the dir, so a
# partial install where the dir exists but metadata never landed is caught).
dep_installed() {
  local dep=$1
  [ -f "${PLUGIN_ROOT}/node_modules/${dep}/package.json" ]
}

# Declared runtime deps — keep in sync with package.json "dependencies".
# The dispatched code imports markdown-it / peggy / yaml at runtime; tsx is
# the runner. A probe that only checked tsx would skip npm install on a
# partial adopter install (tsx present, the rest missing) and then crash on
# Node module resolution at first dispatch.
RUNTIME_DEPS="markdown-it peggy yaml tsx"

# Probe every declared runtime dep.
all_deps_installed() {
  for dep in ${RUNTIME_DEPS}; do
    if ! dep_installed "${dep}"; then
      return 1
    fi
  done
  return 0
}

run_install() {
  echo "stackctl: installing plugin dependencies (first run for v${1:-unknown})..." >&2
  (
    cd "${PLUGIN_ROOT}"
    # --workspaces=false: when sparse-cloned from a workspaces-declaring
    # monorepo, npm would otherwise hoist node_modules/ to the workspace
    # root, leaving ${PLUGIN_ROOT}/node_modules/ empty. Force install into
    # the plugin's own node_modules/.
    npm install --omit=dev --workspaces=false \
      --no-audit --no-fund --loglevel=error
  ) >&2
}

write_sentinel() {
  local version=$1
  [ -n "${version}" ] || return 0
  [ -d "${PLUGIN_ROOT}/node_modules" ] || return 0
  : > "${PLUGIN_ROOT}/node_modules/.deskwork-install-complete-${version}" 2>/dev/null || true
}

sentinel_present() {
  local version=$1
  [ -n "${version}" ] || return 1
  [ -f "${PLUGIN_ROOT}/node_modules/.deskwork-install-complete-${version}" ]
}

TSX_BIN="$(find_tsx || true)"
VERSION="$(plugin_version)"

# Detect workspace dev path: tsx resolved from an ancestor (NOT from
# PLUGIN_ROOT/node_modules itself). The monorepo owns dep resolution there;
# we don't probe the plugin's own node_modules.
IS_WORKSPACE_DEV=0
if [ -n "${TSX_BIN}" ]; then
  case "${TSX_BIN}" in
    "${PLUGIN_ROOT}/node_modules/.bin/tsx")
      IS_WORKSPACE_DEV=0
      ;;
    *)
      IS_WORKSPACE_DEV=1
      ;;
  esac
fi

NEEDS_INSTALL=0
if [ -z "${TSX_BIN}" ]; then
  NEEDS_INSTALL=1
elif [ "${IS_WORKSPACE_DEV}" -eq 0 ]; then
  if sentinel_present "${VERSION}"; then
    NEEDS_INSTALL=0
  elif all_deps_installed; then
    write_sentinel "${VERSION}"
    NEEDS_INSTALL=0
  else
    NEEDS_INSTALL=1
  fi
fi

if [ "${NEEDS_INSTALL}" -eq 1 ]; then
  run_install "${VERSION}"
  TSX_BIN="$(find_tsx || true)"
  if [ -z "${TSX_BIN}" ]; then
    echo "stackctl: npm install completed but tsx is still not resolvable from ${PLUGIN_ROOT}. Aborting." >&2
    exit 1
  fi
  if ! all_deps_installed; then
    echo "stackctl: npm install completed but one or more declared deps are still missing under ${PLUGIN_ROOT}/node_modules. Aborting." >&2
    exit 1
  fi
  write_sentinel "${VERSION}"
fi

exec "${TSX_BIN}" "${PLUGIN_ROOT}/src/cli.ts" "$@"
