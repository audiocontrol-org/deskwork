#!/usr/bin/env bash
#
# deskwork-studio — thin wrapper around @deskwork/studio.
#
# All logic (workspace-bin lookup, first-run install with lock, partial-
# install recovery, exec dispatch) lives in the shared bash runtime at
# vendor/cli-bin-lib/install-lock.sh — see that file's header for the
# detailed behavior contract. This wrapper exists only to bind the bin
# name + plugin root and forward the operator's args.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# shellcheck source=../vendor/cli-bin-lib/install-lock.sh
source "${PLUGIN_ROOT}/vendor/cli-bin-lib/install-lock.sh"

run_with_install_lock \
  --bin-name "deskwork-studio" \
  --plugin-root "${PLUGIN_ROOT}" \
  -- "$@"
